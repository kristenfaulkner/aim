{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/)(?!robots\\.txt)(?!sitemap\\.xml)(?!manifest\\.json).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/integrations/import/trainingpeaks.js": {
      "maxDuration": 300,
      "memory": 3009
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-eightsleep",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-recovery",
      "schedule": "15 * * * *"
    }
  ]
}
