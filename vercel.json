{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/)(?!robots\\.txt)(?!sitemap\\.xml)(?!manifest\\.json).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-eightsleep",
      "schedule": "0 * * * *"
    }
  ]
}
